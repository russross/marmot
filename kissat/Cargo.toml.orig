[package]
name = "kissat"
version = "0.1.0"
edition = "2018"
build = "build.rs"
description = "A simple wrapper for the Kissat SAT solver"
license = "MIT"
repository = "https://github.com/jleahy/kissat-rs"
readme = "README.md"
keywords = ["sat"]
exclude = ["kissat/", "!kissat/src/*.c", "!kissat/src/*.h"]

[build-dependencies]
cc = "1.0"
