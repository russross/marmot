from pyquery import PyQuery as pq
import re

prefixes = {
    'CS':       'Computing',
    'IT':       'Computing',
    'MATH':     'Mathematics',
    'SD':       'Computing',
    'SE':       'Computing',
} 

pages = [ 'cs', 'it', 'math', 'sd', 'se' ]

courses = {}

CONCURRENT_PREREQ_RE = re.compile(
    r'can be (?:concurrently enrolled|taken concurrently)',
    re.IGNORECASE,
)

def parse_requisite_section(desc_html, labels):
    start = -1
    for label in labels:
        start = desc_html.find(label)
        if start >= 0:
            break
    if start < 0:
        return ('', [])

    section = desc_html[start:]
    section = section[section.find(':') + 1:]
    section = section[:section.find('.')]

    links = []
    for elt in pq(section).find('a.bubblelink.code'):
        links.append((elt.text, elt.tail or ''))

    return (section, links)

def crawl_prefix(prefix):
    page = pq(url=f'https://catalog.utahtech.edu/courses/{prefix}/')
    # download from newcatalog as cs.html, etc., and use the following:
    #page = pq(url=f'file:///home/russ/Downloads/{prefix}.html')
    for div in page('.courseblock'):
        title = pq(div).find('p.courseblocktitle strong')[0]
        (course, title, hours) = title.text_content().split('.  ')
        hours = hours[:-1]

        desc = pq(div).find('p.courseblockdesc')
        desc_html = desc.html()
        (_, pre_pairs) = parse_requisite_section(desc_html, ['Prerequisites:', 'Prerequisite:'])
        pre = [code for (code, _) in pre_pairs]

        (_, co_pairs) = parse_requisite_section(desc_html, ['Corequisites:', 'Corequisite:'])
        co = [code for (code, _) in co_pairs]

        # Some prereqs are annotated as allowed concurrent enrollment.
        # These should be modeled as both prereq and coreq.
        for (code, tail) in pre_pairs:
            if CONCURRENT_PREREQ_RE.search(tail):
                if code not in co:
                    co.append(code)

        match = re.search(r'\. (FA)?(?:, )?(SP)?(?:, )?(SU)?\.<br/>', desc_html)
        if match: (fa, sp, su) = (match.group(1) == 'FA', match.group(2) == 'SP', match.group(3) == 'SU')
        else: fa = sp = su = False

        courses[course] = {
            'title': title,
            'pre': pre,
            'co': co,
            'rot': (fa, sp, su),
        }

depts = set()
print('import queries')
print()
print('def build_courses(db: queries.DB) -> None:')
print("    print('building departments')")
for dept in sorted(set(prefixes.values())):
    print(f'    db.make_department({repr(dept)})')

for page in pages:
    crawl_prefix(page)

